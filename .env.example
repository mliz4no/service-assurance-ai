# Copy this file to .env and update the values for your local environment

# API server port
PORT=8080

# PostgreSQL connection string for the local docker DB
DATABASE_URL=postgresql://service_assurance:service_assurance@localhost:5432/service_assurance

# Session secret for auth/session signing
SESSION_SECRET=replace-with-a-secure-random-secret

# OpenAI API key for AI features
OPENAI_API_KEY=

# Optional local development mode
NODE_ENV=development
